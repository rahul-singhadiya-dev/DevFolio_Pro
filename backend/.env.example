# Neon PostgreSQL Connection URL (sslmode=require is required for Neon serverless PostgreSQL)
DATABASE_URL="postgresql://user:password@host/devfolio?sslmode=require&connection_limit=5&pool_timeout=10"

# JWT configuration (Secret used to sign and verify web tokens)
JWT_SECRET="your-super-secure-secret-key-here"
JWT_EXPIRES_IN="24h"

# Admin credentials for single-owner portfolio authentication (email & bcrypt password hash)
# Use scripts/hash-password.js to generate the bcrypt hash of your password
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="$2a$10$YourGeneratedBcryptHashHere"

# SMTP Settings for Nodemailer email notifications on contact form submissions
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# The personal email address where contact form notifications will be sent
NOTIFY_EMAIL="your-personal-email@example.com"

# Cloudinary Configuration for PDF resume and project assets cloud uploading
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Port on which the Express.js server will run
PORT=5000

# Environment state
NODE_ENV="development"
