# ============================================================
# DevFolio Pro — .gitignore
# ============================================================

# ---------------------------
# Dependencies
# ---------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------
# Environment & Secrets
# ---------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ---------------------------
# Build Outputs
# ---------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
.vercel/
.netlify/

# ---------------------------
# Vite / Frontend
# ---------------------------
frontend/dist/
frontend/.vite/
frontend/node_modules/

# ---------------------------
# Backend
# ---------------------------
backend/node_modules/
backend/uploads/
backend/logs/

# ---------------------------
# Prisma
# ---------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
backend/prisma/*.db
backend/prisma/*.db-journal

# ---------------------------
# Logs
# ---------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------
# Runtime / Cache
# ---------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ---------------------------
# Testing
# ---------------------------
coverage/
.nyc_output/

# ---------------------------
# OS Generated Files
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------
# Editor & IDE
# ---------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ---------------------------
# Misc
# ---------------------------
*.pem
*.p12
*.key
*.cert
